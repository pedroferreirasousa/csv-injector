# Copie este arquivo para .env e ajuste os valores para o seu ambiente

APP_NAME="CSV Injector API"
APP_VERSION="1.0.0"

# Origens permitidas no CORS (separadas por vírgula)
ALLOWED_ORIGINS=["http://localhost:3000"]

# Diretório para armazenamento temporário de arquivos CSV
STORAGE_DIR="/tmp"

# Tamanho máximo de arquivo em MB
MAX_FILE_SIZE_MB=10
